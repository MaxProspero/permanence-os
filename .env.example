PERMANENCE_COMMS_DOCTOR_LIVE_TIMEOUT=8
PERMANENCE_COMMS_DOCTOR_REPAIR_TIMEOUT=120
PERMANENCE_COMMS_DOCTOR_ESCALATION_WARN_COUNT=8
# Comms status defaults
PERMANENCE_COMMS_STATUS_LOG_STALE_MINUTES=20
PERMANENCE_COMMS_STATUS_COMPONENT_STALE_MINUTES=120
PERMANENCE_COMMS_STATUS_ESCALATION_DIGEST_STALE_MINUTES=1500
PERMANENCE_COMMS_STATUS_ESCALATION_HOURS=24
PERMANENCE_COMMS_STATUS_ESCALATION_WARN_COUNT=8
PERMANENCE_COMMS_STATUS_VOICE_QUEUE_WARN_COUNT=15
PERMANENCE_COMMS_STATUS_REQUIRE_ESCALATION_DIGEST=0
# Telegram control command mode
PERMANENCE_TELEGRAM_CONTROL_ENABLE_COMMANDS=0
PERMANENCE_TELEGRAM_CONTROL_COMMAND_PREFIX=/
PERMANENCE_TELEGRAM_CONTROL_COMMAND_TIMEOUT=90
PERMANENCE_TELEGRAM_CONTROL_MAX_COMMANDS=3
