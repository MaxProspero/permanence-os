PERMANENCE_PLATFORM_WATCH_TIMEOUT=10
PERMANENCE_PLATFORM_WATCH_LOOKBACK_DAYS=14
PERMANENCE_PLATFORM_WATCH_MIN_SCORE=34
PERMANENCE_PLATFORM_WATCH_MAX_ITEMS=40
