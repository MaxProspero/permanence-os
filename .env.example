PERMANENCE_TELEGRAM_CONTROL_TARGET_CHAT_IDS=
# Optional multiline system prompt for Telegram chat agent behavior
# PERMANENCE_TELEGRAM_CONTROL_CHAT_SYSTEM_PROMPT=You are...
PERMANENCE_TELEGRAM_CONTROL_VOICE_PRIORITY=high
PERMANENCE_TELEGRAM_CONTROL_VOICE_CHANNEL=telegram-voice
PERMANENCE_TELEGRAM_CONTROL_VOICE_SOURCE=
