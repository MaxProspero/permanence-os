# API Keys (add your keys here)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
XAI_API_KEY=
OPENAI_KEYCHAIN_SERVICE=
OPENAI_KEYCHAIN_ACCOUNT=

# Model provider routing
PERMANENCE_MODEL_PROVIDER=anthropic
PERMANENCE_MODEL_PROVIDER_FALLBACKS=anthropic,ollama,openai,xai
PERMANENCE_MODEL_PROVIDER_CAPS_USD=anthropic=35,openai=10,xai=5,ollama=0
PERMANENCE_LLM_MONTHLY_BUDGET_USD=50
PERMANENCE_MODEL_BUDGET_WARNING_RATIO=0.75
PERMANENCE_MODEL_BUDGET_CRITICAL_RATIO=0.90
PERMANENCE_LOW_COST_MODE=0
# Optional model overrides by tier (applies to the active provider)
PERMANENCE_MODEL_OPUS=
PERMANENCE_MODEL_SONNET=
PERMANENCE_MODEL_HAIKU=
PERMANENCE_DEFAULT_MODEL=
# Optional provider-specific model/base URL overrides
PERMANENCE_ANTHROPIC_MODEL_OPUS=
PERMANENCE_ANTHROPIC_MODEL_SONNET=
PERMANENCE_ANTHROPIC_MODEL_HAIKU=
PERMANENCE_ANTHROPIC_DEFAULT_MODEL=
PERMANENCE_OPENAI_BASE_URL=https://api.openai.com/v1
PERMANENCE_OPENAI_MODEL_OPUS=
PERMANENCE_OPENAI_MODEL_SONNET=
PERMANENCE_OPENAI_MODEL_HAIKU=
PERMANENCE_OPENAI_DEFAULT_MODEL=
PERMANENCE_XAI_BASE_URL=https://api.x.ai/v1
PERMANENCE_XAI_MODEL_OPUS=
PERMANENCE_XAI_MODEL_SONNET=
PERMANENCE_XAI_MODEL_HAIKU=
PERMANENCE_XAI_DEFAULT_MODEL=
PERMANENCE_OLLAMA_BASE_URL=http://127.0.0.1:11434
PERMANENCE_OLLAMA_MODEL_OPUS=qwen3:8b
PERMANENCE_OLLAMA_MODEL_SONNET=qwen3:4b
PERMANENCE_OLLAMA_MODEL_HAIKU=qwen2.5:3b
PERMANENCE_OLLAMA_DEFAULT_MODEL=qwen3:4b

# Optional market data API keys (add only if/when you subscribe)
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
COINMARKETCAP_API_KEY=
GLASSNODE_API_KEY=

# System Config
MAX_STEPS=12
MAX_TOOL_CALLS=5
LOG_LEVEL=INFO
PERMANENCE_STORAGE_ROOT=/Volumes/LaCie
PERMANENCE_NOTEBOOKLM_FOLDER_ID=
PERMANENCE_NOTEBOOKLM_SYNC=0
# Run NotebookLM sync only during this local-hour slot (set "all" to run every briefing slot)
PERMANENCE_NOTEBOOKLM_SYNC_SLOT=19
# Run Ari receptionist summary during this local-hour slot (set "all" to run every briefing slot)
PERMANENCE_ARI_ENABLED=0
PERMANENCE_ARI_SLOT=19
# Run weekly phase gate on this local day-of-week at/after evening slot (1=Mon ... 7=Sun)
PERMANENCE_PHASE_GATE_DOW=7
# Run daily promotion cycle (queue auto + promotion review) in briefing automation
PERMANENCE_PROMOTION_DAILY_ENABLED=1
PERMANENCE_PROMOTION_DAILY_SLOT=19
PERMANENCE_PROMOTION_DAILY_STRICT=0
PERMANENCE_PROMOTION_DAILY_SINCE_HOURS=24
PERMANENCE_PROMOTION_DAILY_MAX_ADD=5
# Daytime policy: auto = require phase gate only at/after enforce hour
PERMANENCE_PROMOTION_DAILY_PHASE_POLICY=auto
PERMANENCE_PROMOTION_DAILY_PHASE_ENFORCE_HOUR=19
# Money loop automation (agent summaries + revenue action queue)
PERMANENCE_MONEY_LOOP_GMAIL_INGEST=1
PERMANENCE_MONEY_LOOP_GMAIL_MAX=100
PERMANENCE_MONEY_LOOP_GMAIL_QUERY=newer_than:14d -category:social -category:promotions
PERMANENCE_MONEY_LOOP_TRIAGE_MAX_ITEMS=40
# Comms loop automation (Telegram + Discord relay + glasses + inbox process)
PERMANENCE_COMMS_LOOP_TELEGRAM_ENABLED=1
PERMANENCE_COMMS_LOOP_DISCORD_RELAY_ENABLED=1
PERMANENCE_COMMS_LOOP_GLASSES_ENABLED=1
PERMANENCE_COMMS_LOOP_RESEARCH_PROCESS_ENABLED=1
PERMANENCE_COMMS_LOOP_STATUS_ENABLED=1
PERMANENCE_COMMS_LOOP_TELEGRAM_LIMIT=25
PERMANENCE_COMMS_LOOP_DISCORD_MAX_PER_FEED=20
PERMANENCE_COMMS_LOOP_GLASSES_MAX_FILES=30
PERMANENCE_COMMS_LOOP_TELEGRAM_SKIP_MEDIA=1
PERMANENCE_COMMS_LOOP_COMMS_STATUS_ENABLED=1
PERMANENCE_COMMS_LOOP_PLATFORM_WATCH_ENABLED=1
PERMANENCE_COMMS_LOOP_PLATFORM_WATCH_STRICT=0
PERMANENCE_COMMS_LOOP_COMMS_STATUS_REQUIRE_ESCALATION_DIGEST=0
PERMANENCE_COMMS_LOOP_COMMS_STATUS_LOG_STALE_MINUTES=20
PERMANENCE_COMMS_LOOP_COMMS_STATUS_COMPONENT_STALE_MINUTES=120
PERMANENCE_COMMS_LOOP_COMMS_STATUS_ESCALATION_DIGEST_STALE_MINUTES=720
PERMANENCE_COMMS_LOOP_COMMS_STATUS_ESCALATION_HOURS=24
PERMANENCE_COMMS_LOOP_COMMS_STATUS_ESCALATION_WARN_COUNT=6
PERMANENCE_COMMS_LOOP_COMMS_STATUS_VOICE_QUEUE_WARN_COUNT=12
PERMANENCE_COMMS_LOOP_DIGEST_ENABLED=0
PERMANENCE_COMMS_LOOP_DIGEST_SEND=0
PERMANENCE_COMMS_LOOP_DOCTOR_ENABLED=0
PERMANENCE_COMMS_LOOP_DOCTOR_ALLOW_WARNINGS=1
PERMANENCE_COMMS_LOOP_ESCALATION_DIGEST_ENABLED=0
PERMANENCE_COMMS_LOOP_ESCALATION_DIGEST_SEND=0
# Comms digest defaults
PERMANENCE_COMMS_DIGEST_SEND_DEFAULT=0
PERMANENCE_COMMS_DIGEST_MAX_WARNINGS=8
# Comms doctor defaults
PERMANENCE_COMMS_DOCTOR_MAX_STALE_MINUTES=45
PERMANENCE_COMMS_DOCTOR_DIGEST_MAX_STALE_MINUTES=1500
PERMANENCE_COMMS_DOCTOR_REQUIRE_DIGEST=0
PERMANENCE_COMMS_DOCTOR_REQUIRE_ESCALATION_DIGEST=0
