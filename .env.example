PERMANENCE_DISCORD_RELAY_ESCALATE=1
PERMANENCE_DISCORD_RELAY_ESCALATE_TO_RECEPTION=1
PERMANENCE_DISCORD_RELAY_ESCALATION_NOTIFY=1
PERMANENCE_DISCORD_RELAY_ESCALATION_MIN_PRIORITY=high
PERMANENCE_DISCORD_RELAY_ESCALATION_TELEGRAM_MIN_PRIORITY=high
PERMANENCE_DISCORD_RELAY_ESCALATION_DISCORD_MIN_PRIORITY=urgent
